# -----------------------------
# EHI Ignite API runtime config
# -----------------------------

# Required for Anthropic assistant mode.
ANTHROPIC_API_KEY=replace_with_real_key

# Assistant runtime mode:
# - deterministic
# - anthropic
PROVIDER_ASSISTANT_MODE=anthropic

# If anthropic mode fails, fallback to deterministic assistant.
PROVIDER_ASSISTANT_FALLBACK_TO_DETERMINISTIC=true

# Anthropic runtime tuning
PROVIDER_ASSISTANT_MODEL=claude-sonnet-4-5
PROVIDER_ASSISTANT_MAX_TURNS=6
# Optional budget cap in USD, blank to disable
PROVIDER_ASSISTANT_MAX_BUDGET_USD=

# Web tools (keep off by default for clinical safety)
PROVIDER_ASSISTANT_ENABLE_WEB_SEARCH=false
PROVIDER_ASSISTANT_ENABLE_WEB_FETCH=false

# Optional environment tag
ENVIRONMENT=development

# Tracing / Observability
TRACING_ENABLED=false
TRACES_API_ENABLED=false
# LANGFUSE_PUBLIC_KEY=pk_...
# LANGFUSE_SECRET_KEY=sk_...
# LANGFUSE_HOST=https://cloud.langfuse.com
