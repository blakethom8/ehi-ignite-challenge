FROM node:22-alpine

WORKDIR /app

COPY cursor-sidecar/package.json cursor-sidecar/package-lock.json* ./
RUN npm install --omit=dev

COPY cursor-sidecar/tsconfig.json ./
COPY cursor-sidecar/src ./src

RUN npm install --include=dev && npm run build && npm prune --omit=dev

ENV CURSOR_SIDECAR_PORT=3040
EXPOSE 3040

CMD ["node", "dist/server.js"]
