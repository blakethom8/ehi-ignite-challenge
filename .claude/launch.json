{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["api.main:app", "--reload", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "Frontend",
      "runtimeExecutable": "/opt/homebrew/bin/npm",
      "runtimeArgs": ["run", "dev", "--prefix", "app"],
      "port": 5173
    },
    {
      "name": "Patient Journey App",
      "runtimeExecutable": ".venv/bin/streamlit",
      "runtimeArgs": ["run", "patient-journey/app.py"],
      "port": 8501
    },
    {
      "name": "FHIR Explorer",
      "runtimeExecutable": ".venv/bin/streamlit",
      "runtimeArgs": ["run", "fhir_explorer/app.py"],
      "port": 8502
    },
    {
      "name": "Wireframes",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8765", "--directory", "design/wireframes"],
      "port": 8765
    },
    {
      "name": "EHI Atlas Console",
      "runtimeExecutable": ".venv/bin/streamlit",
      "runtimeArgs": ["run", "ehi-atlas/app/streamlit_app.py", "--server.port", "8503"],
      "port": 8503
    }
  ]
}
